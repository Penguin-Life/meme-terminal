# ═══════════════════════════════════════════════════════════════════════════════
#  Meme Terminal — Root .env.example
#  Copy to backend/.env for backend vars, and frontend/.env for frontend vars.
#  See docs/ENV-VARS.md for full documentation.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Backend: Server ──────────────────────────────────────────────────────────
PORT=3902
NODE_ENV=development

# ─── Backend: Demo Mode ───────────────────────────────────────────────────────
# Set to true to use mock data — great for demos/testing without hitting APIs
DEMO_MODE=false

# ─── Backend: CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Backend: Telegram Notifications (optional) ───────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Backend: Solana RPC (optional — public endpoint used by default) ─────────
# Free tier: https://www.helius.dev/
HELIUS_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Backend: Optional enrichment APIs ───────────────────────────────────────
# BIRDEYE_API_KEY=      # Enhanced Solana token data
# ETHERSCAN_API_KEY=    # EVM wallet portfolio data

# ─── Backend: Binance Spot Trading (optional — testnet supported) ─────────────
# Get keys from https://www.binance.com/en/my/settings/api-management
# For testnet: https://testnet.binance.vision/
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Copy this to frontend/.env and prefix with VITE_
VITE_API_URL=http://localhost:3902/api
