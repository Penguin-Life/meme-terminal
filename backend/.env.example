# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3902
NODE_ENV=production

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true to use mock data — perfect for demos/judging without API keys!
# All endpoints return realistic sample data instantly.
DEMO_MODE=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://meme.yourdomain.com

# ─── Telegram Notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Webhook Notifications ────────────────────────────────────────────────────
# Optional: generic webhook URL (receives POST with JSON payload)
WEBHOOK_URL=

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Optional: use a dedicated RPC for better performance
# Free tier: https://www.helius.dev/
HELIUS_API_KEY=

# ─── Optional: Custom RPC endpoint ───────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Binance Trading (required for /api/trade endpoints) ─────────────────────
# Get your API key from https://www.binance.com/en/my/settings/api-management
# ⚠️ NEVER enable withdrawal permission!
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true   # Set to "false" for mainnet (real money!)

# ─── WebSocket Real-time Prices ──────────────────────────────────────────────
WS_ENABLED=true

# ─── Data APIs (all free, no key needed by default) ──────────────────────────
# DexScreener, GeckoTerminal, Pump.fun — no keys required
# BIRDEYE_API_KEY=    # Optional: for enhanced Solana token data
# ETHERSCAN_API_KEY=  # Optional: for EVM wallet portfolio data
