# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3902
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://meme.yourdomain.com

# ─── Telegram Notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Optional: use a dedicated RPC for better performance
# Free tier: https://www.helius.dev/
HELIUS_API_KEY=

# ─── Optional: Custom RPC endpoint ───────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Data APIs (all free, no key needed by default) ──────────────────────────
# DexScreener, GeckoTerminal, Pump.fun — no keys required
# BIRDEYE_API_KEY=    # Optional: for enhanced Solana token data
# ETHERSCAN_API_KEY=  # Optional: for EVM wallet portfolio data
